{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "DebugAgents": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=orders.db"
  },
  "AppSettings": {
    "AppName": "Order Management Demo",
    "MaxItems": 100,
    "CacheTtlSeconds": 30,
    "CleanupIntervalSeconds": 60
  },
  "Authentication": {
    "DefaultScheme": "Bearer",
    "Schemes": {
      "Bearer": {
        "Authority": "https://login.microsoftonline.com/demo",
        "Audience": "api://demo"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE" ],
    "AllowCredentials": true
  },
  "DebugAgent": {
    "Enabled": true,
    "BasePath": "/agent",
    "Llm": {
      "BaseUrl": "https://open.bigmodel.cn/api/coding/paas/v4",
      "ApiKey": "",
      "Model": "glm-5.2",
      "Temperature": 0.3,
      "MaxTokens": 4096,
      "MaxToolRounds": 15,
      "TimeoutSeconds": 120
    }
  }
}
